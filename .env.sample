# .env.sample — 환경변수 템플릿 (형상관리 포함)
# 사용법: 이 파일을 복사하여 .env 로 저장한 후 실제 값을 입력하세요.
#   cp .env.sample .env

# ════════════════════════════════════════════
#  AI Pro LLM  (Samsung 사내 AI 플랫폼)
# ════════════════════════════════════════════
AIPRO_ENDPOINT=https://<aiPro-endpoint>
AIPRO_API_KEY=<발급받은-api-key>
AIPRO_MODEL=aiPro-default
AIPRO_EMBEDDING_MODEL=aiPro-embedding

# ════════════════════════════════════════════
#  Febrix 벡터DB
# ════════════════════════════════════════════
FEBRIX_ENDPOINT=https://<febrix-endpoint>
FEBRIX_API_KEY=<발급받은-api-key>

# ════════════════════════════════════════════
#  GitHub Enterprise
# ════════════════════════════════════════════
GITHUB_ENTERPRISE_URL=https://<사내-github-url>
GITHUB_TOKEN=<github-pat>
GITHUB_ORG=<조직명>

# ════════════════════════════════════════════
#  Confluence
# ════════════════════════════════════════════
CONFLUENCE_URL=https://<confluence-url>
CONFLUENCE_TOKEN=<api-token>
CONFLUENCE_DEFAULT_SPACE=<기본-스페이스-키>

# ════════════════════════════════════════════
#  JSM (Jira Service Management)
# ════════════════════════════════════════════
JSM_URL=https://<jsm-url>
JSM_TOKEN=<api-token>
JSM_PROJECT_KEY=<프로젝트-키>

# ════════════════════════════════════════════
#  두드림 (요청관리 시스템)
# ════════════════════════════════════════════
DOODREAM_URL=https://<두드림-url>
DOODREAM_TOKEN=<api-token>

# ════════════════════════════════════════════
#  Oracle 19c  (Read-only 계정)
# ════════════════════════════════════════════
ORACLE_DSN=<host>:<port>/<service_name>
ORACLE_USER=<readonly-user>
ORACLE_PASSWORD=<password>
ORACLE_DEFAULT_OWNER=<스키마-오너(대문자)>

# ════════════════════════════════════════════
#  자체 개발 관리 시스템
# ════════════════════════════════════════════
MASTER_SYSTEM_URL=https://<master-system-url>
MASTER_SYSTEM_TOKEN=<api-token>

DICTIONARY_URL=https://<dictionary-url>
DICTIONARY_TOKEN=<api-token>

# ════════════════════════════════════════════
#  개발 모드
# ════════════════════════════════════════════
# T3 Skill 개발 중에는 true, 실 연동 테스트 시 false
USE_MOCK_CONNECTORS=true

# ════════════════════════════════════════════
#  로깅
# ════════════════════════════════════════════
LOG_LEVEL=INFO
